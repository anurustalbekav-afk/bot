# Copy to .env and edit values for your environment.

# Session lifetime in seconds (default: 7 days)
SESSION_TTL=604800

# Comma-separated list of logins or emails that should always be treated as
# admins. Useful for seeding the very first admin without editing the JSON
# data file by hand. Subsequent admins can be promoted by setting
# `isAdmin: true` on their record in data/users.json.
# Example:
# ADMIN_LOGINS=root,admin@fear.dev
ADMIN_LOGINS=
