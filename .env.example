# Скопируй в .env и поменяй значения для продакшена
PORT=3000

# Длинная случайная строка для подписи сессий. ОБЯЗАТЕЛЬНО смени в проде.
AUTH_SECRET=change-me-to-a-long-random-string

# Время жизни сессии в секундах (по умолчанию 7 дней)
SESSION_TTL=604800

# --- MySQL / MariaDB (phpMyAdmin) ------------------------------------------
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=fear_dev
DB_CONNECTION_LIMIT=10
